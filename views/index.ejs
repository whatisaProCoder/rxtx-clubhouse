<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RXTX Clubhouse</title>
  <link rel="stylesheet" href="/styles.css">
</head>

<body>
  <%- include("./partials/header") %>
    <div class="content-container">
      <div class="content">
        <% if(locals.currentUser) {%>
          <div class="welcome-banner">
            <% if(!currentUser.is_member && !currentUser.is_admin) { %>
              <div class="greeting-section">
                <div class="greeting">Welcome, <%= currentUser.firstname %>!</div>
                <div class="subtext">Join a club to become a member.</div>
              </div>
              <a class="banner-button" href="/membership/code">
                Get Membership
              </a>
              <% } else if(currentUser.is_member) { %>
                <div class="greeting-section">
                  <div class="greeting">Welcome, <%= currentUser.firstname %>!</div>
                  <div class="subtext">You are a member of this exclusive club.</div>
                </div>
                <a class="banner-button" href="/post/new">
                  New Post
                </a>
                <% } %>
          </div>
          <% } %>
            <div class="posts-section">
              <div class="title">Posts</div>
              <div class="posts-container">
                <% for(let i=0;i<10;i++) { %>
                  <%- include("./partials/post.ejs") %>
                    <% } %>
              </div>
            </div>
            <% if(!locals.currentUser) { %>
              <div class="end-of-page-prompt">
                <div class="chip">Discuss about computers, robotics and electronics by joining the club</div>
                <div class="action-links">
                  <a href="/auth/log-in">Login</a> or <a href="/auth/sign-up">Sign Up</a>
                </div>
              </div>
              <% } %>
      </div>
    </div>
    </div>
</body>

</html>