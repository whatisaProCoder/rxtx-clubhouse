<div class="post">
  <img src="/user-icon.svg" alt="Avatar" class="avatar">
  <div class="flex-row">
    <div class="post-content">
      <div class="user-name">
        <% if(currentUser?.is_member) { %>
          <%=post.firstname %>
            <%= post.lastname %>
              <% } else {%>
                Anonymous
                <% } %>
      </div>
      <div class="post-main">
        <span class="post-title">
          <%= post.title %> <span class="dot">•</span>
        </span> <span class="post-body">
          <%= post.body %>
        </span>
      </div>
    </div>
    <div class="info-section">
      <div class="date-chip">
        <%= new Intl.DateTimeFormat('en-IN', { dateStyle:'medium' , timeStyle: 'short' } ).format(new
          Date(post.created_at)) %>
      </div>
    </div>
  </div>

</div>